# --- büyük veri (repo dışı; kaynak fotoğraflar/çizimler ve üretilen indeksler)
cad_png/
cad_dwg/
photos/

# --- index: yalnız insan-onaylı küçük dosyalar repoya girer
index/*
!index/excluded_trivial.json
!index/eklenen_kapilar.json

# --- data: yalnız etiketler ve donmuş ayrım repoya girer (asıl insan emeği)
data/*
