*.pyc
.claude/
.codex/
.agents/
selftest_sonuc.txt
build_log.txt
iss_log.txt

# --- paketleme varlıkları (repo dışı; büyük ikili, build sırasında toplanır)
modeller/
araclar/
FUARAHSAP_Kurulum.exe

# --- dist: sadece kurulum betiği repoya girer
dist/*
